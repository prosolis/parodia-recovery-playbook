# Synapse config for parodia.dev — authored clean (NOT copied from etke).
# Copy across from etke ONLY: the signing key file + the three secrets marked below.
# Full reference: https://element-hq.github.io/synapse/latest/usage/configuration/config_documentation.html

server_name: "parodia.dev"            # NEVER change — this is the federation identity
public_baseurl: "https://matrix.parodia.dev/"
pid_file: /data/homeserver.pid
signing_key_path: "/data/homeserver.signing.key"   # <-- copy this FILE verbatim from etke

listeners:
  - port: 8008
    tls: false
    type: http
    x_forwarded: true                 # behind Traefik; trust X-Forwarded-*
    bind_addresses: ['0.0.0.0']
    resources:
      - names: [client, federation]   # 443-only: federation served on the same listener
        compress: false

database:
  name: psycopg2
  args:
    user: synapse
    password: "${POSTGRES_PASSWORD}"  # Synapse doesn't expand env by default — see note below
    dbname: synapse
    host: postgres
    cp_min: 5
    cp_max: 10

# --- Secrets: copy these THREE values verbatim from etke's homeserver.yaml ---
# Keeping them identical means existing access tokens & login sessions survive the move.
macaroon_secret_key: "REPLACE_FROM_ETKE"
form_secret: "REPLACE_FROM_ETKE"
registration_shared_secret: "REPLACE_FROM_ETKE"
# ----------------------------------------------------------------------------

media_store_path: "/data/media-store"
max_upload_size: "1024M"             # matches etke (confirmed 2026-06-28)
enable_authenticated_media: true     # MSC3916 — etke had it on; keep on (current Synapse default)

default_room_version: "12"           # matches etke; needs current Synapse (latest is fine)

enable_registration: false           # closed; we move to MAS+Authentik for signup later
report_stats: false

# --- TURN / VoIP (coturn) ---------------------------------------------------
# The shared secret MUST equal coturn's static-auth-secret (compose injects it from
# ${TURN_SHARED_SECRET}). Synapse does NOT expand env in YAML — paste the literal
# secret here (this file is gitignored; the .example carries the placeholder).
turn_uris:
  - "turn:matrix.parodia.dev?transport=udp"
  - "turn:matrix.parodia.dev?transport=tcp"
  # Add the turns: (TLS) URIs once coturn has the matrix.parodia.dev cert wired:
  # - "turns:matrix.parodia.dev?transport=udp"
  # - "turns:matrix.parodia.dev?transport=tcp"
turn_shared_secret: "REPLACE_FROM_ENV"   # = TURN_SHARED_SECRET (fresh; not etke's)
turn_user_lifetime: 86400000
turn_allow_guests: false
# ----------------------------------------------------------------------------

trusted_key_servers:
  - server_name: "matrix.org"

log_config: "/data/log.config"

## ============================================================================
