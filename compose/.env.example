# Copy to .env and fill in. .env is gitignored.

# Postgres password for the Synapse DB (pick a strong one; only used internally).
POSTGRES_PASSWORD=

# Confirmed on parodia.dev (2026-06-20): mash-traefik routable network is `traefik`,
# cert resolver is `default`, entrypoint is `web-secure` (hardcoded in compose labels).
PROXY_NETWORK=traefik
CERT_RESOLVER=default

# --- TURN / coturn (VoIP calls) ---
# Generate a FRESH secret (do not reuse etke's): `openssl rand -hex 32`.
# This MUST match `turn_shared_secret` in synapse/homeserver.yaml.
TURN_SHARED_SECRET=
# Public IPv4 of the parodia.dev box — coturn advertises this as the relay address.
TURN_EXTERNAL_IP=178.104.56.222
TURN_REALM=parodia.dev
